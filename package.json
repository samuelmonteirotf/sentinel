{
  "name": "sentinel",
  "version": "0.1.0",
  "private": false,
  "description": "Edge bot-firewall: real-time request scoring + adaptive rate limiting on Cloudflare Workers. No paid Bot Management — the heuristics are the product.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "vitest": "^3.0.5",
    "wrangler": "^4.90.0"
  }
}
